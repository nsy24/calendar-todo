# Supabase（既存）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# タスク名の自動翻訳（いずれか1つを設定。未設定時はモック＝原文のまま全言語表示）
# DeepL（推奨・無料枠あり）: https://www.deepl.com/pro-api
DEEPL_API_KEY=
# 無料枠の場合は省略可（デフォルトで api-free.deepl.com を使用）。有料は https://api.deepl.com
# DEEPL_API_URL=https://api-free.deepl.com

# Google Cloud Translation API: https://cloud.google.com/translate/docs
# GOOGLE_TRANSLATE_API_KEY=

# オプション: サーバー側から /api/translate を呼ぶ場合のベースURL（例: Vercel の URL）
# NEXT_PUBLIC_APP_URL=http://localhost:3000
